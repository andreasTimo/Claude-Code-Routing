# Proxy listen settings
PORT=8787
HOST=127.0.0.1

# Optional shared token required by clients calling this proxy.
# Leave empty to accept any Authorization header.
PROXY_AUTH_TOKEN=

# Retry/fallback behavior
REQUEST_TIMEOUT_MS=120000
STREAM_IDLE_TIMEOUT_MS=60000
SSE_HEARTBEAT_MS=0
MAX_ATTEMPTS=3

# Configure providers either with ANTHROPIC_PROVIDER_* variables:
ANTHROPIC_PROVIDER_1_NAME=qcode-personal
ANTHROPIC_PROVIDER_1_BASE_URL=https://api.anthropic.com
ANTHROPIC_PROVIDER_1_AUTH_TOKEN=sk-ant-xxx

ANTHROPIC_PROVIDER_2_NAME=qcode-work
ANTHROPIC_PROVIDER_2_BASE_URL=https://api.anthropic.com
ANTHROPIC_PROVIDER_2_AUTH_TOKEN=sk-ant-yyy

# Or with PROVIDERS_JSON:
# PROVIDERS_JSON=[{"name":"qcode-personal","baseUrl":"https://api.anthropic.com","authToken":"sk-ant-xxx"},{"name":"qcode-work","baseUrl":"https://api.anthropic.com","authToken":"sk-ant-yyy"}]
